# LLM Configuration
LLM_PROVIDER=ollama
LLM_BASE_URL=http://your-llm-server-ip:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma4:26b

# OpenAI
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini

# Embedding Configuration
EMBEDDING_BASE_URL=http://your-embedding-server-ip:8003/v1
EMBEDDING_MODEL=nvidia/Nemotron-3-Embed-1B-BF16


# Weaviate Vector Database Configuration
WEAVIATE_HOST=127.0.0.1
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_ENABLE_MODULES=text2vec-ollama,generative-ollama
WEAVIATE_QUERY_DEFAULTS_LIMIT=25
WEAVIATE_ANONYMOUS_ACCESS=true

# Ollama 原生 API 端點 (給非 OpenAI 相容套件使用)
OLLAMA_API_ENDPOINT=http://your-llm-server-ip:11434

# SQL Server Notebook Storage
DB_SERVER=your-sql-server
DB_NAME=your-database
DB_USER=your-user
DB_PASSWORD=your-password